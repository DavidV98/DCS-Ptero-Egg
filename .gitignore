# ── DCS / Wine runtime data (never commit — tens of GB, user-specific) ──────
.wine/
serverdata/
*.miz
!missions/example/*.miz
Saved Games/
_downloads/

# ── DCS installer (downloaded at build/install time, ~17MB+) ────────────────
DCS_World_Server_modular.exe
dcs_installer.exe
*.exe

# ── Secrets / credentials (NEVER commit) ────────────────────────────────────
# Real ED account credentials must never be checked in.
autologin.lua
# DCS encrypted ED credential store — NEVER commit
network.vault
*.vault
*.secret
.env
credentials.txt

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
Logs/
dcs.log

# ── OS / editor cruft ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.idea/
.vscode/
*.bak

# ── Docker local build artifacts ───────────────────────────────────────────
*.tar
